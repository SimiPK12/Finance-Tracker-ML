# ─── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── ML API (optional - defaults to localhost:8000 in development) ────────────
# Set this to your Render.com service URL after deploying the ML API
# Example: https://nexus-finance-ml-api.onrender.com
NEXT_PUBLIC_ML_API_URL=https://your-ml-api.onrender.com
